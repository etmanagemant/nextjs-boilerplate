# Vercel Deployment Optimization
# Exclude files that are not needed in production

# ⚠️ DO NOT EXCLUDE node_modules - Playwright MUST be installed!

# Source Control
.git
.gitignore
.github

# Documentation
README.md
*.md
SETUP_*.md
CONTENT_PLAN_*.md
ADMIN_CHATTER_*.md
ARCHITECTURE_BLUEPRINT.md
AGENTS.md
CLAUDE.md

# Database Setup Files (not needed in production)
*.sql
SETUP_*.sql
*_SETUP.sql
*_MIGRATION.sql
*_FIX.sql

# Development
.env.example
.env.local
.vscode
.sidecar
.eslintrc*

# Caches only (not actual node_modules!)
node_modules/.cache
.next/cache

# Build outputs (Next.js builds this)
.next
dist
build

# Large files that don't belong in serverless
scripts/
